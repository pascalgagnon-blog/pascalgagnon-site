---
layout: base.njk
title: Accueil
description: Réflexions sur la technologie, les affaires et la vie.
---

<section class="hero">
  <div class="container">
      <h1>Pascal Gagnon</h1>
          <p>Réflexions sur la technologie, les affaires et la vie.</p>
            </div>
            </section>

            <section class="articles-section">
              <div class="container">
                  <h2 class="section-title">Articles récents</h2>

                      {% if collections.posts.length %}
                            <div class="articles-grid">
                                    {% for post in collections.posts %}
                                              <a href="{{ post.url }}" class="article-card">
                                                          <div class="article-card-date">
                                                                        {{ post.date | dateReadable }}
                                                                                    </div>
                                                                                                <h3 class="article-card-title">{{ post.data.title }}</h3>
                                                                                                            {% if post.data.description %}
                                                                                                                          <p class="article-card-excerpt">{{ post.data.description }}</p>
                                                                                                                                      {% endif %}
                                                                                                                                                  <span class="article-card-link">Lire l'article →</span>
                                                                                                                                                            </a>
                                                                                                                                                                    {% endfor %}
                                                                                                                                                                          </div>
                                                                                                                                                                              {% else %}
                                                                                                                                                                                    <p>Aucun article pour le moment. Revenez bientôt !</p>
                                                                                                                                                                                        {% endif %}
                                                                                                                                                                                          </div>
                                                                                                                                                                                          </section>
